# ==========================================================================
# API
# ==========================================================================
NODE_ENV=development
PORT=3000
API_URL=

# Base PÚBLICA do link próprio do Elo (spec 0016): a mensagem de cobrança usa
# APP_URL/r/:token. Em produção: https://useadimplo.com.br. Em dev: localhost.
APP_URL=http://localhost:3000

# Base PÚBLICA do FRONTEND (SPA). O /r/:token redireciona o pagador para
# WEB_APP_URL/pagar/:token (página de acordo — spec 0018 / M2). Deixe vazio para
# manter o comportamento antigo (redirect direto ao checkout do gateway).
# Dev: http://localhost:5173. Prod: https://useadimplo.com.br.
WEB_APP_URL=http://localhost:5173

# Salt do hash de IP nos eventos de interação (RN-ELO6 — nunca guardamos IP cru).
# Gere um valor aleatório qualquer; sem ele o ipHash sai só do IP (menos privado).
EVENT_IP_SALT=""

# true  = a API também consome a fila (monólito)
# false = use um worker isolado (npm run worker) para evitar consumidor duplicado
RUN_WORKER_INLINE=true

# ==========================================================================
# Banco de dados (PostgreSQL)
# ==========================================================================
DATABASE_URL="postgresql://user:pass@localhost:5432/billing"

# ==========================================================================
# RabbitMQ
# ==========================================================================
RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# ==========================================================================
# Infra do docker-compose / Swarm (interpolado pelo compose; não vai no app)
# O compose monta DATABASE_URL/RABBITMQ_URL a partir destes valores.
# ==========================================================================
POSTGRES_DB=billing_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha-forte
RABBITMQ_USER=billing
RABBITMQ_PASSWORD=troque-esta-senha-forte
# Imagem publicada (use tag versionada / ECR em produção)
API_IMAGE=billing-api:latest

# ==========================================================================
# Redis (cache opcional)
# ==========================================================================
REDIS_ENABLED=false
REDIS_URL="redis://localhost:6379"

# ==========================================================================
# WhatsApp
# log   = não envia de verdade (só loga) — default, ideal p/ dev/testes
# cloud = envia via Meta WhatsApp Cloud API (requer as vars abaixo)
# ==========================================================================
WHATSAPP_PROVIDER=log

# Só necessárias quando WHATSAPP_PROVIDER=cloud.
# WHATSAPP_TOKEN: token de acesso (temporário do painel de teste, ou permanente
#   de um System User em produção). WHATSAPP_PHONE_NUMBER_ID: id do número (não
#   é o telefone; é o "Phone number ID" que aparece no painel do WhatsApp).
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v20.0                     # opcional (default v20.0)
# WHATSAPP_BASE_URL=https://graph.facebook.com   # opcional (default)

# ==========================================================================
# Autenticação (JWT) — rotas internas
# Usuários reais logam via POST /api/auth/register + /login (spec 0002).
# AUTH_USERNAME/PASSWORD são OPCIONAIS: conta de serviço de bootstrap (fallback).
# ==========================================================================
JWT_SECRET="troque-por-um-segredo-forte-e-aleatorio"
JWT_EXPIRES_IN="1h"
AUTH_USERNAME="admin"
AUTH_PASSWORD="troque-esta-senha"
# Tenant da conta de serviço (default = Account seedado na migração 0001).
DEFAULT_TENANT_ID="00000000-0000-0000-0000-000000000001"

# Console da plataforma (spec 0031): o super-admin é uma identidade SEPARADA
# (tabela PlatformAdmin), não um tenant. O 1º admin é criado por bootstrap:
#   npm run create-admin   (ou no container: node scripts/create-admin.mjs)
# lendo as variáveis abaixo. Nunca há auto-cadastro de admin.
PLATFORM_ADMIN_BOOTSTRAP_EMAIL=""
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=""
PLATFORM_ADMIN_BOOTSTRAP_NAME="Administrador"
# Validade do token de impersonação (curto, por segurança).
IMPERSONATION_EXPIRES_IN="30m"

# ==========================================================================
# Gateway de pagamento (spec 0003)
# infinitepay = link de checkout (PIX+cartão) — DEFAULT p/ comercialização
# mercadopago = Checkout Pro | mock = simulado (use em dev/testes)
# ==========================================================================
PAYMENT_PROVIDER=infinitepay

# Cobrança do PRÓPRIO SaaS (spec 0020): gateway da conta da Adimplo que cobra os
# tenants pela assinatura. Independente do gateway de cada tenant. Default mock
# (funciona em dev/demo). Em produção, aponte p/ o provider real + credenciais
# dele nas envs correspondentes (ver spec 0020 / D-24).
PLATFORM_PAYMENT_PROVIDER=mock

# InfinitePay (necessário quando PAYMENT_PROVIDER=infinitepay)
# INFINITEPAY_HANDLE: seu identificador de lojista (o nome no link do checkout,
#   ex.: checkout.infinitepay.io/SEU_HANDLE). Obrigatório.
INFINITEPAY_HANDLE=
# INFINITEPAY_REDIRECT_URL: (opcional) pra onde o cliente volta após pagar.
INFINITEPAY_REDIRECT_URL=
# Opcionais (só mude se necessário — já têm default):
# INFINITEPAY_CHECKOUT_URL=https://checkout.infinitepay.io
# INFINITEPAY_API_URL=https://api.infinitepay.io

# Webhook do provider MOCK (POST /api/invoices/webhook) — header x-webhook-secret
WEBHOOK_SECRET="troque-por-um-segredo-forte-e-aleatorio"

# ==========================================================================
# Segredo de operações de SISTEMA/cron (cross-tenant) — spec 0010
# Protege POST /api/system/billing/run (header x-cron-secret). O agendador
# (cron/EventBridge/n8n) usa este segredo. Gere um valor forte e aleatório.
# ==========================================================================
CRON_SECRET="troque-por-um-segredo-forte-e-aleatorio"

# ==========================================================================
# Cifra de segredos por tenant em repouso (D-17)
# Usada para cifrar segredos por tenant no banco: token do WhatsApp e as
# credenciais dos gateways de pagamento (spec 0019).
# Gere: openssl rand -hex 32   (64 caracteres hex = 32 bytes).
# OBRIGATÓRIA para SALVAR credencial de gateway/WhatsApp; segredos legados em
# texto continuam legíveis sem ela (recifrados no próximo save).
# ==========================================================================
ENCRYPTION_KEY=""

# ==========================================================================
# Backup off-site (S3-compatível) — scripts/backup-db.sh
# Ative definindo BACKUP_S3_BUCKET. MESMO script serve AWS S3 (agora) e
# Cloudflare R2 / Backblaze B2 (depois) — só muda ENDPOINT + credenciais.
# ==========================================================================
BACKUP_S3_BUCKET=""
# BACKUP_S3_PREFIX=backups                 # pasta dentro do bucket (default: backups)

# AWS S3:  deixe o ENDPOINT vazio e ajuste a região da sua conta.
# Cloudflare R2:  BACKUP_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#                 AWS_DEFAULT_REGION=auto
BACKUP_S3_ENDPOINT=""
AWS_DEFAULT_REGION="us-east-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Mercado Pago (necessário quando PAYMENT_PROVIDER=mercadopago)
MP_ACCESS_TOKEN="TEST-xxxxxxxx"                # token de sandbox
MP_WEBHOOK_SECRET="segredo-de-assinatura-do-mp"
MP_NOTIFICATION_URL="https://SEU_DOMINIO/api/invoices/webhook"
MP_BASE_URL="https://api.mercadopago.com"

# ==========================================================================
# Multi-gateway (spec 0019) — as credenciais REAIS ficam por TENANT (cifradas
# no banco, via tela de Configurações). As variáveis abaixo servem só como
# FALLBACK de dev/sandbox e para apontar a BASE URL (produção x homologação).
# Cada empresa escolhe o gateway que já tem; nada disso é obrigatório aqui.
# ==========================================================================
# Asaas
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"
# ASAAS_API_KEY=""
# ASAAS_WEBHOOK_TOKEN=""
# PagBank / PagSeguro
PAGBANK_BASE_URL="https://sandbox.api.pagseguro.com"
# PAGBANK_TOKEN=""
# Efí (Gerencianet) — PIX exige certificado mTLS (por tenant)
EFI_BASE_URL="https://cobrancas-h.api.efipay.com.br"
# EFI_CLIENT_ID=""
# EFI_CLIENT_SECRET=""
# EFI_WEBHOOK_TOKEN=""
# Stripe (use sk_test_... para modo de teste)
STRIPE_BASE_URL="https://api.stripe.com"
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_SUCCESS_URL=""
# Pagar.me
PAGARME_BASE_URL="https://api.pagar.me/core/v5"
# PAGARME_SECRET_KEY=""
# PAGARME_WEBHOOK_SECRET=""
