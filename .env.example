# ==========================================================================
# API
# ==========================================================================
NODE_ENV=development
PORT=3000
API_URL=

# true  = a API também consome a fila (monólito)
# false = use um worker isolado (npm run worker) para evitar consumidor duplicado
RUN_WORKER_INLINE=true

# ==========================================================================
# Banco de dados (PostgreSQL)
# ==========================================================================
DATABASE_URL="postgresql://user:pass@localhost:5432/billing"

# ==========================================================================
# RabbitMQ
# ==========================================================================
RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# ==========================================================================
# Infra do docker-compose / Swarm (interpolado pelo compose; não vai no app)
# O compose monta DATABASE_URL/RABBITMQ_URL a partir destes valores.
# ==========================================================================
POSTGRES_DB=billing_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha-forte
RABBITMQ_USER=billing
RABBITMQ_PASSWORD=troque-esta-senha-forte
# Imagem publicada (use tag versionada / ECR em produção)
API_IMAGE=billing-api:latest

# ==========================================================================
# Redis (cache opcional)
# ==========================================================================
REDIS_ENABLED=false
REDIS_URL="redis://localhost:6379"

# ==========================================================================
# WhatsApp
# log   = não envia de verdade (só loga) — default, ideal p/ dev/testes
# cloud = envia via Meta WhatsApp Cloud API (requer as vars abaixo)
# ==========================================================================
WHATSAPP_PROVIDER=log

# Só necessárias quando WHATSAPP_PROVIDER=cloud.
# WHATSAPP_TOKEN: token de acesso (temporário do painel de teste, ou permanente
#   de um System User em produção). WHATSAPP_PHONE_NUMBER_ID: id do número (não
#   é o telefone; é o "Phone number ID" que aparece no painel do WhatsApp).
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v20.0                     # opcional (default v20.0)
# WHATSAPP_BASE_URL=https://graph.facebook.com   # opcional (default)

# ==========================================================================
# Autenticação (JWT) — rotas internas
# Usuários reais logam via POST /api/auth/register + /login (spec 0002).
# AUTH_USERNAME/PASSWORD são OPCIONAIS: conta de serviço de bootstrap (fallback).
# ==========================================================================
JWT_SECRET="troque-por-um-segredo-forte-e-aleatorio"
JWT_EXPIRES_IN="1h"
AUTH_USERNAME="admin"
AUTH_PASSWORD="troque-esta-senha"
# Tenant da conta de serviço (default = Account seedado na migração 0001).
DEFAULT_TENANT_ID="00000000-0000-0000-0000-000000000001"

# ==========================================================================
# Gateway de pagamento (spec 0003)
# mock = simulado (default) | mercadopago = Checkout Pro real (sandbox)
# ==========================================================================
PAYMENT_PROVIDER=mock

# Webhook do provider MOCK (POST /api/invoices/webhook) — header x-webhook-secret
WEBHOOK_SECRET="troque-por-um-segredo-forte-e-aleatorio"

# Mercado Pago (necessário quando PAYMENT_PROVIDER=mercadopago)
MP_ACCESS_TOKEN="TEST-xxxxxxxx"                # token de sandbox
MP_WEBHOOK_SECRET="segredo-de-assinatura-do-mp"
MP_NOTIFICATION_URL="https://SEU_DOMINIO/api/invoices/webhook"
MP_BASE_URL="https://api.mercadopago.com"
