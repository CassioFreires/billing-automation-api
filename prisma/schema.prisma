generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Conta/tenant do SaaS. Todo dado de negócio pertence a um Account (ver SDD/specs/0001-multi-tenancy.md).
model Account {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("ACTIVE") // ACTIVE, SUSPENDED
  createdAt DateTime @default(now())
  // Prova de aceite dos Termos/Política no cadastro (spec 0022, LGPD).
  acceptedTermsAt      DateTime?
  acceptedTermsVersion String?
  clients   Client[]
  invoices  Invoice[]
  users     User[]
  subscriptions Subscription[]
  payments  Payment[]
  interactionEvents InteractionEvent[]
  paymentSetting PaymentSetting?
  whatsappSetting WhatsappSetting?
  negotiationSetting NegotiationSetting?
  agreements Agreement[]
  platformSubscription PlatformSubscription?
  platformInvoices PlatformInvoice[]
  onboardingState OnboardingState?
  reguaSetting ReguaSetting?
  channelSetting ChannelSetting?
  recoveryCases RecoveryCase[]
  recoveryAttempts RecoveryAttempt[]
  clientHealth ClientHealth[]
}

// Assinatura do PRÓPRIO SaaS (spec 0020): a Adimplo cobra o tenant. 1:1 com
// Account. Distinto de `Subscription` (recorrência do tenant com os clientes DELE).
// plan: free | essencial | pro   ·   status: trialing | active | past_due | canceled
model PlatformSubscription {
  id               String    @id @default(uuid())
  plan             String    @default("free")
  status           String    @default("trialing")
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  lastUpdate       DateTime  @updatedAt

  tenantId String  @unique
  account  Account @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Cobrança da plataforma (Adimplo → tenant) por um período. Espelha Invoice, mas
// é da assinatura do SaaS. `gatewayId` é o localizador do webhook de plataforma.
model PlatformInvoice {
  id           String    @id @default(uuid())
  plan         String
  amountCents  Int
  period       String // "YYYY-MM"
  status       String    @default("PENDING") // PENDING | PAID | FAILED
  gatewayId    String?   @unique
  checkoutUrl  String?
  pixCopyPaste String?
  paidAt       DateTime?
  createdAt    DateTime  @default(now())

  tenantId String
  account  Account @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Regras de AUTONEGOCIAÇÃO por tenant (spec 0018 — M2, "Botão de Alívio de Caixa").
// O dono define UMA vez os limites do que o Adimplo pode oferecer sozinho ao
// pagador que hesita (abriu o link N vezes e não pagou — Elo, spec 0016). O
// sistema NUNCA oferece além destes tetos (RN-NEG2).
model NegotiationSetting {
  id                  String   @id @default(uuid())
  enabled             Boolean  @default(false) // liga/desliga o alívio no tenant
  hesitationOpens     Int      @default(3)     // limiar de aberturas (DEFAULT_HESITATION_OPENS)
  discountEnabled     Boolean  @default(false)
  discountPercent     Decimal  @default(0) @db.Decimal(5, 4) // 0..1 (ex.: 0.1000 = 10%)
  installmentsEnabled Boolean  @default(false)
  maxInstallments     Int      @default(1)     // teto de parcelas
  deferEnabled        Boolean  @default(false)
  deferMaxDays        Int      @default(0)     // teto de dias de adiamento
  deferFeePercent     Decimal  @default(0) @db.Decimal(5, 4) // taxa sobre o valor ao adiar
  createdAt           DateTime @default(now())
  lastUpdate          DateTime @updatedAt

  tenantId            String   @unique
  account             Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Acordo de autonegociação (spec 0018 — M2). Nasce quando o pagador aceita uma
// opção de alívio: gera uma NOVA cobrança (newInvoice) e "supersede" a original
// (que vai para RENEGOTIATED). `terms` guarda o SNAPSHOT dos valores aplicados
// (RN-NEG11) — imune a mudanças posteriores no NegotiationSetting.
model Agreement {
  id                String   @id @default(uuid())
  type              String   // discount | installments | defer
  status            String   @default("PENDING") // PENDING | ACCEPTED | CANCELLED | EXPIRED
  terms             Json     // { originalValue, finalValue, discountPercent?, installments?, newDueDate?, feePercent? }
  createdAt         DateTime @default(now())
  lastUpdate        DateTime @updatedAt

  originalInvoiceId String
  originalInvoice   Invoice  @relation("AgreementOriginal", fields: [originalInvoiceId], references: [id], onDelete: Cascade)

  newInvoiceId      String?  @unique
  newInvoice        Invoice? @relation("AgreementNew", fields: [newInvoiceId], references: [id], onDelete: SetNull)

  tenantId          String
  account           Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([originalInvoiceId])
  @@index([tenantId])
  @@index([originalInvoiceId, status]) // guarda do "1 acordo ativo por fatura" (RN-NEG3)
}

// Estado do ONBOARDING guiado por tenant (spec 0021). O progresso dos passos é
// DERIVADO de dados reais (tem gateway? tem cliente? tem fatura?); esta tabela só
// guarda as flags de UI que não dão para derivar: dispensa manual do checklist e
// "pular" o passo opcional de WhatsApp. A linha só nasce quando o dono dispensa/pula.
model OnboardingState {
  id              String   @id @default(uuid())
  dismissed       Boolean  @default(false) // dono fechou o checklist manualmente
  whatsappSkipped Boolean  @default(false) // pulou o passo opcional de WhatsApp
  createdAt       DateTime @default(now())
  lastUpdate      DateTime @updatedAt

  tenantId        String   @unique
  account         Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Régua de cobrança POR TENANT (spec 0026). Sequência de lembretes ao longo do
// tempo. `steps` é um JSON: [{ offsetDays, message? }] ordenado por offset. O
// agendador diário envia o próximo passo devido de cada fatura em aberto.
model ReguaSetting {
  id         String   @id @default(uuid())
  enabled    Boolean  @default(false)
  steps      Json     @default("[]") // [{ offsetDays: number, message?: string }]
  createdAt  DateTime @default(now())
  lastUpdate DateTime @updatedAt

  tenantId   String   @unique
  account    Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Canal de envio das cobranças POR TENANT (spec 0032). A empresa escolhe por
// onde a régua dispara: whatsapp (padrão), email ou both (ambos). O e-mail é
// mock-first (provider 'log') — plugar SMTP/SendGrid real fica para depois.
model ChannelSetting {
  id         String   @id @default(uuid())
  channel    String   @default("whatsapp") // whatsapp | email | both
  createdAt  DateTime @default(now())
  lastUpdate DateTime @updatedAt

  tenantId   String   @unique
  account    Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Configuração de WhatsApp POR TENANT (spec 0014). Cada empresa envia pelo
// próprio número. provider 'log' (default) não envia; 'cloud' usa a Meta Cloud
// API com as credenciais do tenant.
// ⚠️ token é sensível: mascarado na API (write-only) e — antes de multi-tenant
// em produção — deve ser criptografado em repouso (mesma pendência do MP).
model WhatsappSetting {
  id            String   @id @default(uuid())
  provider      String   @default("log") // log | cloud
  phoneNumberId String?  // "Phone number ID" da Meta (não é o telefone)
  token         String?  // access token da Cloud API (secreto)
  apiVersion    String?  // ex.: v20.0 (default no código)
  createdAt     DateTime @default(now())
  lastUpdate    DateTime @updatedAt

  tenantId      String   @unique
  account       Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Configuração de pagamento POR TENANT (spec 0012 + 0019 multi-gateway).
// Cada empresa escolhe o provider que já usa e informa suas credenciais.
// provider: infinitepay | mercadopago | mock | asaas | pagbank | efi | stripe | pagarme
// - Campos NÃO-secretos ficam em colunas (ex.: handle público do InfinitePay).
// - Segredos (apiKey/token/secretKey/...) ficam em `credentialsEnc`: um JSON
//   específico do provider, CIFRADO em repouso (AES-256-GCM, prefixo enc:v1:).
model PaymentSetting {
  id                String   @id @default(uuid())
  provider          String   @default("infinitepay")
  infinitepayHandle String?  // handle público do lojista (checkout.infinitepay.io/<handle>)
  redirectUrl       String?  // retorno opcional pós-pagamento
  credentialsEnc    String?  // JSON de segredos do provider, cifrado (spec 0019)
  createdAt         DateTime @default(now())
  lastUpdate        DateTime @updatedAt

  tenantId          String   @unique
  account           Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Idempotência de webhooks (spec 0003): guarda os ids de evento já processados.
model WebhookEvent {
  id         String   @id // event id do provedor (idempotency key)
  provider   String
  receivedAt DateTime @default(now())
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("OWNER") // OWNER (futuro: ADMIN, MEMBER)
  createdAt    DateTime @default(now())

  tenantId     String
  account      Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Client {
  id        String   @id @default(uuid())
  name      String
  phone     String
  document  String
  email     String?  // canal de e-mail (spec 0032) — opcional
  status    String   @default("EM_DIA")
  debtValue Decimal  @default(0.0) @db.Decimal(12, 2)
  processed     Boolean   @default(false)
  portalToken   String?   @unique // link do Portal do pagador (spec 0027) — todas as cobranças dele
  anonymizedAt  DateTime? // LGPD: quando o titular foi anonimizado (spec 0004)
  lastUpdate    DateTime  @updatedAt
  createdAt DateTime @default(now())
  invoices  Invoice[]
  subscriptions Subscription[]
  interactionEvents InteractionEvent[]
  recoveryCases RecoveryCase[]
  health        ClientHealth? // Radar de Risco (spec 0035) — 1:1

  tenantId  String
  account   Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, phone]) // telefone único por tenant (RN-T3)
  @@index([status])
  @@index([tenantId, status])
}

model Invoice {
  id            String    @id @default(uuid())
  value         Decimal   @db.Decimal(12, 2)
  status        String    @default("PENDING") // PENDING, PAID, OVERDUE, FAILED, RENEGOTIATED (spec 0018)
  pixCopyPaste  String?   // Campo para salvar o "Copia e Cola" do PIX gerado pelo Gateway
  pixQrCode     String?   // Link ou Base64 da imagem do QR Code
  checkoutUrl   String?   // URL de checkout hospedado (ex.: Mercado Pago Checkout Pro)
  gatewayId     String?   @unique // Localizador da fatura no gateway (global entre tenants)
  linkToken     String?   @unique // Token do link PRÓPRIO do Adimplo (/r/:token) — Fundação "Elo" (spec 0016). Global entre tenants (resolvido como o webhook).
  dueDate       DateTime  // Data de vencimento da cobrança
  paidAt        DateTime? // Data que o webhook confirmou o pagamento
  createdAt     DateTime  @default(now())
  notificationSent  Boolean   @default(false)
  // Régua de cobrança (spec 0026): quantos passos já enviados e quando o último.
  reminderStep   Int       @default(0)
  lastReminderAt DateTime?

  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tenantId      String
  account       Account   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  items         InvoiceItem[] // detalhe do que está sendo cobrado (spec 0007)
  payments      Payment[]     // recebimentos (manual + gateway) — spec 0015
  events        InteractionEvent[] // eventos de interação (Elo) — spec 0016
  recoveryCase  RecoveryCase? // caso de recuperação de pagamento falho (spec 0033, F1)

  // Autonegociação (spec 0018 — M2): acordos onde esta fatura é a ORIGINAL
  // (renegociada) ou a NOVA (gerada pelo acordo).
  agreementsAsOriginal Agreement[] @relation("AgreementOriginal")
  agreementAsNew       Agreement?  @relation("AgreementNew")

  // Origem recorrente (spec 0009): quando a fatura foi gerada por uma assinatura.
  // period = "YYYY-MM" da competência; o par garante 1 fatura por assinatura/mês.
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  period         String?       // competência YYYY-MM (apenas para faturas recorrentes)

  @@unique([subscriptionId, period]) // idempotência da geração recorrente (RN-R3)
  @@index([clientId])
  @@index([status])
  @@index([status, clientId]) // Índice composto para otimizar o método findPendingInvoices
  @@index([tenantId, status])
  @@index([tenantId, clientId])
  @@index([tenantId, status, dueDate]) // filtro (tenant+status) + ordenação por dueDate (lista de pendentes)
}

// Assinatura / mensalidade recorrente (spec 0009). Um "molde" de cobrança que,
// a cada competência (mês), gera uma Invoice via POST /api/subscriptions/run.
model Subscription {
  id          String   @id @default(uuid())
  description String   // o que é cobrado (vira o item da fatura gerada)
  amount      Decimal  @db.Decimal(12, 2) // valor mensal
  dayOfMonth  Int      @default(10) // dia de vencimento (1..28, evita fim de mês)
  status      String   @default("ACTIVE") // ACTIVE, PAUSED, CANCELED
  startDate   DateTime @default(now())
  nextRunDate DateTime // quando a próxima fatura deve ser gerada
  createdAt   DateTime @default(now())
  lastUpdate  DateTime @updatedAt

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tenantId    String
  account     Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  invoices    Invoice[]

  @@index([clientId])
  @@index([tenantId, status])
  @@index([status, nextRunDate]) // varredura da geração: ACTIVE com nextRunDate vencido
}

// Item/linha de uma fatura: o QUE está sendo cobrado (produto/serviço).
// O valor total da fatura é a soma de quantity * unitPrice dos itens (spec 0007).
model InvoiceItem {
  id          String   @id @default(uuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// Recebimento de uma fatura (spec 0015). Fonte ÚNICA do "dinheiro que entrou":
// nasce do gateway (webhook, source=gateway) OU de uma baixa manual
// (source=manual: dinheiro, transferência, maquininha, boleto pago no banco…).
model Payment {
  id         String   @id @default(uuid())
  amount     Decimal  @db.Decimal(12, 2)
  method     String?  // pix | dinheiro | transferencia | cartao | boleto | outro (obrigatório na baixa manual, via DTO)
  source     String   // manual | gateway
  paidAt     DateTime // data do recebimento
  note       String?  // observação livre
  receiptUrl String?  // comprovante (upload real = futuro; v1 aceita URL)
  createdAt  DateTime @default(now())

  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  tenantId   String
  account    Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([tenantId])
  @@index([tenantId, paidAt]) // Cockpit (M4): soma de recebimentos por período
}

// Evento de interação do ciclo de vida da cobrança (spec 0016 — Fundação "Elo").
// Fonte ÚNICA e APPEND-ONLY do COMPORTAMENTO do pagador: link criado, enviado,
// entregue/lido/falhou (por canal), aberto, tentou pagar, pago. É a substância da
// autonegociação (M2, o rosto), do Cockpit (M4) e do Score (M5).
// A identidade cross-tenant do pagador (Payer) é follow-up (M5, com trava LGPD);
// aqui o evento se liga a invoiceId/clientId (o Client já é o pagador no tenant).
model InteractionEvent {
  id         String   @id @default(uuid())
  type       String   // link_created | sent | delivered | read | failed | open | pay_attempt | paid
  channel    String?  // whatsapp | sms | email | web
  metadata   Json?    // MÍNIMO: { ua?, ipHash?, providerMessageId? } — sem IP cru / PII (RN-ELO6)
  occurredAt DateTime // quando o evento de fato ocorreu (pode diferir de createdAt)
  createdAt  DateTime @default(now())

  invoiceId  String?
  invoice    Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  tenantId   String
  account    Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([invoiceId, type])      // contagem do Botão de Alívio (open>=N e sem paid)
  @@index([tenantId, occurredAt]) // timeline / Cockpit (M4)
}

// Auditoria de ações do super-admin da plataforma (spec 0023). Rastro de quem
// (adminEmail), o quê (action), em qual tenant (targetTenantId) e quando.
model AdminAuditLog {
  id             String   @id @default(uuid())
  adminEmail     String
  action         String // suspend | activate | change_plan | impersonate
  targetTenantId String
  meta           Json?
  createdAt      DateTime @default(now())

  @@index([targetTenantId])
  @@index([createdAt])
}

// Administrador da PLATAFORMA (spec 0031). Identidade do staff do SaaS (você),
// TOTALMENTE separada de User/Account (tenant): não tem tenantId, clínica nem
// trial. Criado por script (npm run create-admin), nunca por auto-cadastro.
model PlatformAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("SUPERADMIN") // SUPERADMIN | SUPPORT
  createdAt    DateTime @default(now())
  lastUpdate   DateTime @updatedAt
}

// Caso de recuperação de pagamento falho (spec 0033 — F1 "Guardião da Receita").
// Orbita UMA fatura vencida: roda uma sequência adaptativa (lembrar → trocar canal
// → ofertar alívio) até recuperar (webhook PAID / aceite de acordo) ou esgotar.
model RecoveryCase {
  id             String    @id @default(uuid())
  reason         String    @default("overdue") // overdue | payment_failed | pix_unpaid | card_expired
  status         String    @default("open")    // open | recovering | recovered | lost | cancelled
  amountAtRisk   Decimal   @db.Decimal(12, 2)
  currentStep    Int       @default(0)
  lastChannel    String?   // whatsapp | email (canal do último envio)
  reliefOffered  Boolean   @default(false)     // já ofertou alívio neste caso (não repetir)
  nextActionAt   DateTime?
  openedAt       DateTime  @default(now())
  resolvedAt     DateTime?
  outcome        String?   // paid | agreement | sem_resposta | cancelado_pelo_dono
  lastUpdate     DateTime  @updatedAt

  invoiceId      String    @unique // 1 caso por fatura (idempotência de abertura — RN-3301)
  invoice        Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  clientId       String
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  subscriptionId String?   // preenchido quando a fatura veio de assinatura (metadado)

  tenantId       String
  account        Account   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  attempts       RecoveryAttempt[]

  @@index([tenantId, status, nextActionAt]) // varredura do sweep (casos devidos por tenant)
  @@index([tenantId, status])
}

// Cada ação tomada num caso de recuperação (auditoria da sequência).
model RecoveryAttempt {
  id         String   @id @default(uuid())
  step       Int
  channel    String?  // whatsapp | email
  action     String   // remind | switch_channel | offer_relief
  result     String?  // sent | failed | opened | paid
  occurredAt DateTime @default(now())

  caseId     String
  case       RecoveryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  tenantId   String
  account    Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, caseId])
}

// Radar de Risco (spec 0035 — F2). Saúde/score do cliente, 1:1 com Client.
model ClientHealth {
  id         String   @id @default(uuid())
  score      Int      // 0..100 (100 = saudável)
  band       String   // healthy | watch | at_risk
  signals    Json     // explicabilidade: { avgDaysLate, trendUp, missedRecurring, openOverdue, maxDaysOverdue, opensNoPay, lostCases, hasHistory }
  computedAt DateTime @default(now())

  clientId   String   @unique
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tenantId   String
  account    Account  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, band])
}
